{
    "layer": "top", // Waybar at top layer
    "spacing": 5, // Gaps between modules (4px)
    "modules-left": ["hyprland/workspaces", "mpris"],
    "modules-center": ["clock"],
    "modules-right": ["privacy", "hyprland/language", "backlight", "pulseaudio", "network", "bluetooth", "battery"],

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        // "format-charging": "{capacity}% ΎΩπ",
        // "format-plugged": "{capacity}% ΎΘο",
        // "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["≤░ΓΟ ", "≤░Β║ ", "≤░Β╗ ", "≤░Β╝ ", "≤░Β╜ ", "≤░Β╛ ", "≤░Β┐ ", "≤░ΓΑ ", "≤░ΓΒ ", "≤░ΓΒ ", "≤░ΓΓ ", "≤░Β╣ "],
        "on-click": "~/scripts/wofi_logout.sh"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "{volume}% ≤░Ξυ ",
        "format-source-muted": "≤░Ξφ ",
        "format-icons": {
            "headphone": "ΎΑξ ",
            "hands-free": "ΎΨΡ ",
            "headset": "ΎΨΡ ",
            "phone": "ΎΓΧ ",
            "portable": "ΎΓΧ ",
            "car": "ΎΗ╣ ",
            "default": ["ΎΑο ", "ΎΑπ ", "ΎΑρ "]
        },
        "on-click": "pkill myxer || myxer",
    },
      "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{signalStrength}% {icon}",
        "format-alt": "{essid} ({signalStrength}%) {icon}",
        "format-ethernet": "{ipaddr}/{cidr} ΎηΨ",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "Disconnected έγι",
        // "format-alt": "{ifname}: {ipaddr}/{cidr}"
        "format-icons": ["≤░νθ ", "≤░νλ ", "≤░νξ ", "≤░νρ "]
    },
    "clock": {
        // "format-alt": "{:%d %m %Y}",
        "format-alt": "{:%A, %d %B %Y, %R}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "on-click-right": "mode",
            "format": {
                "months":     "<span color='#ebbcba'><b>{}</b></span>",
                "days":       "<span color='#e0def4'><b>{}</b></span>",
                "weeks":      "<span color='#9ccfd8'><b>W{}</b></span>",
                "weekdays":   "<span color='#c4a7e7'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
        }
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["≤▒ΟΨ "]
    },
    "mpris": {
	"format": "{artist} - {title} {player_icon}",
	"format-paused": "{artist} - {title} {status_icon}",
    "title-len": 35,
    "artist-len": 35,
	"player-icons": {
		"default": "",
		// "mpv": "ΏθΟ╡"
	},
	"status-icons": {
		"paused": "≤░Πν"
	},
	// "ignored-players": ["firefox"]
    },
    "bluetooth": {
        // "controller": "controller1", // specify the alias of the controller if there are more than 1 on the system
        "format": "ΎΛΦ {status}",
        "format-disabled": "ΎΛΦ disabled", // an empty format will hide the module
        "format-connected": "ΎΛΦ {num_connections} connected",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "pkill wofi ; pkill blueman-manager || blueman-manager",
        "on-click-right": "~/scripts/toggle_bluetooth.sh"
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "≤░πη",
            "default": "≤░πθ"
        },
    },
    "hyprland/language": {
        "format": "{}",
        "format-en": "en ≤░ΝΝ ",
        "format-ru": "ru ≤░ΝΝ ",
        "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next"
    },
    "privacy": {
        "icon-spacing": 4,
        "icon-size": 18,
        "transition-duration": 250,
        "modules": [
            {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-out",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-in",
                "tooltip": true,
                "tooltip-icon-size": 24
            }
        ]
    },
    "custom/wf-recorder": {
		"format": "ΎΑ╜  ",
		"interval": "once",
		"exec": "echo 'Recording' ",
		"exec-if": "pgrep 'wf-recorder'",
		"on-click": "exec $HOME/scripts/wofi_wf_recorder.sh",
		"signal": 8
	}
}
